# Copy to key.properties in this folder (android/) and fill in values.
# Never commit key.properties or *.jks — they are gitignored.
#
# Generate keystore (run once, outside the repo or in android/):
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload

storePassword=your-store-password
keyPassword=your-key-password
keyAlias=upload
storeFile=upload-keystore.jks
